# =============================================================================
# k8sgpt-auto-heal environment configuration
# Copy this file to .env and fill in the values
# =============================================================================

# --- GitHub Configuration ---
# Personal Access Token with repo scope (for Flux bootstrap and PR creation)
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Your GitHub username or organization
GITHUB_USER=your-github-username
# Repository name for the GitOps fleet repo (will be created if it doesn't exist)
GITHUB_REPO=k8sgpt-fleet-demo
# Branch name
GITHUB_BRANCH=main

# --- Anthropic Configuration ---
# API key for Claude (used by K8sGPT operator AND the watcher/Claude Code)
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Model to use for K8sGPT analysis
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# --- Claude Code Configuration ---
# Set to "api" to use Anthropic API directly, or "claude-code" to shell out to claude CLI
REMEDIATION_MODE=api
# Max tokens for remediation generation
MAX_TOKENS=4096

# --- Optional: Flux MCP Server ---
# Set to "true" to install the Flux MCP server (experimental)
INSTALL_FLUX_MCP=false

# --- Optional: Dry Run ---
# Set to "true" to have the watcher log fixes without creating PRs
DRY_RUN=false
